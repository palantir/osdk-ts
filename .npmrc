# npm registry
registry=https://registry.npmjs.org/

# pnpm 10 Security Configuration
# See: https://pnpm.io/npmrc

# Require approval for transitive deps with build scripts
strict-dep-builds=true

# Delay newly published packages by 3 days (4320 minutes)
minimum-release-age=4320
minimum-release-age-exclude[]=@osdk/*

# Prevent trust level downgrades
trust-policy=no-downgrade
# Automatically ignore trust downgrades after 90 days (129600 minutes)
trust-policy-ignore-after=129600

# TODO: Remove storybook exclusions once Storybook 10.x packages pass the minimum-release-age threshold
# Storybook 10.x exclusions (recently published, needed for Storybook MCP)
# Direct dependencies:
minimum-release-age-exclude[]=storybook@10.2.10
minimum-release-age-exclude[]=@storybook/addon-links@10.2.10
minimum-release-age-exclude[]=@storybook/addon-mcp@0.2.3
minimum-release-age-exclude[]=@storybook/addon-themes@10.2.10
minimum-release-age-exclude[]=@storybook/react-vite@10.2.10
minimum-release-age-exclude[]=eslint-plugin-storybook@10.2.10
# Transitive dependencies from @storybook/react-vite and @storybook/addon-mcp:
minimum-release-age-exclude[]=@storybook/builder-vite@10.2.10
minimum-release-age-exclude[]=@storybook/csf-plugin@10.2.10
minimum-release-age-exclude[]=@storybook/react@10.2.10
minimum-release-age-exclude[]=@storybook/react-dom-shim@10.2.10
minimum-release-age-exclude[]=@storybook/mcp@0.2.2

# Trust exceptions for packages with known false-positive trust downgrades
# vite@6.3.6 flagged due to npm publisher settings change, not a security issue
trust-policy-exclude[]=vite@6.3.6
# TODO: Remove storybook trust exclusions once publisher settings stabilize
# @storybook packages flagged due to npm publisher settings change
trust-policy-exclude[]=storybook@10.2.10
trust-policy-exclude[]=@storybook/addon-links@10.2.10
trust-policy-exclude[]=@storybook/addon-mcp@0.2.3
trust-policy-exclude[]=@storybook/addon-themes@10.2.10
trust-policy-exclude[]=@storybook/react-vite@10.2.10
trust-policy-exclude[]=@storybook/builder-vite@10.2.10
trust-policy-exclude[]=@storybook/csf-plugin@10.2.10
trust-policy-exclude[]=@storybook/react@10.2.10
trust-policy-exclude[]=@storybook/react-dom-shim@10.2.10
trust-policy-exclude[]=@storybook/mcp@0.2.2

# Block exotic subdependencies (git repos, tarballs)
block-exotic-subdeps=true

# Hoist ESLint and Prettier plugins to root node_modules
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
