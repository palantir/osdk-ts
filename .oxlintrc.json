{
  "plugins": ["react", "typescript", "import", "jsx-a11y", "oxc"],
  "jsPlugins": ["./plugins/oxlint-plugin-header.js"],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "settings": {
    "react": {
      "version": "18"
    }
  },
  "categories": {},
  "options": {
    "typeAware": true
  },
  "rules": {
    "palantir-header/header": "error",

    "typescript/adjacent-overload-signatures": "warn",
    "typescript/consistent-type-assertions": "warn",
    "typescript/consistent-type-imports": "error",
    "typescript/no-extraneous-class": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-misused-new": "warn",
    "typescript/no-require-imports": "warn",
    "typescript/no-this-alias": "warn",
    "typescript/no-unsafe-function-type": "warn",
    "typescript/no-wrapper-object-types": "warn",
    "typescript/prefer-for-of": "warn",
    "typescript/prefer-namespace-keyword": "warn",
    "typescript/triple-slash-reference": "warn",
    "typescript/unified-signatures": "warn",

    "eqeqeq": ["error", "always", { "null": "never" }],
    "guard-for-in": "warn",
    "no-bitwise": "warn",
    "no-caller": "warn",
    "no-cond-assign": "warn",
    "no-console": "error",
    "no-debugger": "warn",
    "no-duplicate-case": "warn",
    "no-empty": "warn",
    "no-eval": "warn",
    "no-extra-bind": "warn",
    "no-new-func": "warn",
    "no-new-wrappers": "warn",
    "no-shadow": "warn",
    "no-sequences": "warn",
    "no-sparse-arrays": "warn",
    "no-template-curly-in-string": "warn",
    "no-unused-expressions": "warn",
    "no-unsafe-finally": "warn",
    "no-unused-labels": "warn",
    "no-useless-escape": "warn",
    "no-var": "warn",
    "object-shorthand": "warn",
    "prefer-object-spread": "warn",
    "radix": "warn",
    "use-isnan": "warn",
    "no-unused-vars": [
      "warn",
      {
        "ignoreRestSiblings": true,
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "fix": {
          "imports": "safe-fix"
        }
      }
    ],
    "prefer-const": "warn",

    "react/rules-of-hooks": "warn",
    "react/exhaustive-deps": "warn",
    "react/jsx-key": "warn",
    "react/no-string-refs": "warn",

    "import/no-default-export": "warn",
    "import/no-duplicates": "error",

    "typescript/no-floating-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-misused-promises": "warn",
    "typescript/dot-notation": "warn",
    "typescript/restrict-template-expressions": "warn",
    "typescript/require-await": "warn",
    "typescript/unbound-method": "warn",
    "typescript/no-unnecessary-template-expression": "warn",
    "typescript/no-unnecessary-boolean-literal-compare": "warn",
    "typescript/no-redundant-type-constituents": "warn",
    "typescript/no-confusing-void-expression": "warn",
    "typescript/restrict-plus-operands": "warn",
    "typescript/use-unknown-in-catch-callback-variable": "warn",
    "typescript/only-throw-error": "warn",
    "typescript/prefer-reduce-type-parameter": "warn",
    "typescript/prefer-promise-reject-errors": "warn",
    "typescript/no-base-to-string": "warn",
    "typescript/return-await": "warn",
    "typescript/no-deprecated": "warn",

    "typescript/no-unnecessary-type-assertion": "off",
    "typescript/no-duplicate-type-constituents": "off",
    "typescript/no-unnecessary-type-arguments": "off",
    "typescript/no-unnecessary-condition": "off",
    "typescript/no-unnecessary-type-parameters": "off",
    "typescript/no-meaningless-void-operator": "off",
    "typescript/no-unsafe-assignment": "off",
    "typescript/no-unsafe-member-access": "off",
    "typescript/no-unsafe-return": "off",
    "typescript/no-unsafe-argument": "off",
    "typescript/no-unsafe-call": "off"
  },
  "overrides": [
    {
      "files": [
        "**/bin/*.mjs",
        "**/bin/*.cjs",
        "examples-extra/**/*",
        "packages/e2e.sandbox.*/**/*"
      ],
      "rules": {
        "palantir-header/header": "off"
      }
    },
    {
      "files": [
        "**/*.test.ts",
        "**/test/*",
        "examples-extra/**/*",
        "packages/e2e.sandbox.*/**/*",
        "packages/typescript-sdk-docs-examples/**/*"
      ],
      "rules": {
        "no-console": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-base-to-string": "off",
        "typescript/await-thenable": "warn",
        "typescript/no-deprecated": "warn"
      }
    },
    {
      "files": ["**/*.tsx"],
      "rules": {
        "react/jsx-boolean-value": "warn",
        "react/jsx-no-target-blank": "warn",
        "react/self-closing-comp": "warn",

        "jsx-a11y/alt-text": "warn",
        "jsx-a11y/anchor-is-valid": "warn",
        "jsx-a11y/aria-props": "warn",
        "jsx-a11y/aria-proptypes": "warn",
        "jsx-a11y/heading-has-content": "warn",
        "jsx-a11y/no-aria-hidden-on-focusable": "warn",
        "jsx-a11y/role-has-required-aria-props": "warn",
        "jsx-a11y/tabindex-no-positive": "warn"
      }
    }
  ],
  "ignorePatterns": [
    "**/*.js",
    "**/tsup.config.bundled_*",
    "**/vitest.config.mts.timestamp-*",
    "**/build/",
    "**/dist",
    "**/node_modules/",
    "**/src/generatedNoCheck/",
    "**/src/generatedNoCheck2/",
    "**/templates/",
    "examples/**/*",
    "packages/monorepo.*/**",
    "google-font-mocked-response.js",
    ".lintstagedrc.mjs",
    "tests/"
  ]
}
