{
  "typescript": {
    "lineWidth": 80,
    "conditionalExpression.operatorPosition": "nextLine",
    "quoteProps": "preserve",
    "indentWidth": 2
  },
  "json": {
    "indentWidth": 2
  },
  "markdown": {},
  "toml": {},
