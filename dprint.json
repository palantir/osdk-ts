{
  "typescript": {
    "lineWidth": 80,
    "conditionalExpression.operatorPosition": "nextLine",
    "quoteProps": "preserve",
    "indentWidth": 2
  },
  "json": {
    "indentWidth": 2
  },
  "markdown": {},
  "toml": {},
  "excludes": [
    "**/*-lock.json",
    "**/build",
    "**/.turbo",
    "**/src/generatedNoCheck/",
    "**/src/generatedNoCheck2/",
    // create-app/create-widget scaffold content is shipped to generated
    // projects and formatted for those projects (oxfmt via the templates'
    // own oxfmt.config.ts), so it must not be reformatted by the monorepo's
    // dprint. The generated examples exercise this content under oxfmt/oxlint.
    "**/templates/",
    "pnpm-lock.yaml",
    ".vscode/settings.json",
    "examples/",
    "examples-extra/**/dist",
    "**/tsup.config.bundled_*",
    "**/api-docs/",
    "**/*.report.api.md",
    // The shared.* packages below are formatted by oxfmt, not dprint (oxc migration, see oxfmt.config.ts)
    "packages/shared.net.errors/",
    "packages/shared.client.impl/",
    "packages/shared.net.fetch/",
    "packages/shared.net/",
    "packages/language-models/",
    "packages/react-sdk-docs/",
    "packages/typescript-sdk-docs/",
    "packages/widget.client-react/",
    "packages/widget.api/",
    "packages/widget.client/",
    "packages/cbac-components/",
    "packages/react/",
    "packages/react-devtools/",
    "packages/react-components-storybook/",
    "packages/react-components/",
    "packages/client.unstable/",
    "packages/client.unstable.tpsa/",
    "packages/client/",
    "packages/maker/",
    "packages/maker-experimental/",
    "packages/maker-import/",
    "packages/api/",
    "packages/functions/",
    "packages/unit-testing/",
    "packages/aip-core/",
    "packages/foundry-config-json/",
    "packages/seed-compiler/",
    "packages/seed-helpers/",
    "packages/oauth/",
    "packages/faux/",
    "packages/osdk-docs-context/"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.90.4.wasm",
    "https://plugins.dprint.dev/json-0.19.2.wasm",
    "https://plugins.dprint.dev/markdown-0.16.4.wasm",
    "https://plugins.dprint.dev/toml-0.6.1.wasm"
  ]
}
