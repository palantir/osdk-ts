{
  "name": "@osdk/ontology-explorer-app",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/palantir/osdk-ts.git"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./build/types/index.d.ts",
        "default": "./build/esm/index.js"
      },
      "default": "./build/esm/index.js"
    },
    "./ontology-graph": {
      "import": {
        "types": "./build/types/public/ontology-graph.d.ts",
        "default": "./build/esm/public/ontology-graph.js"
      },
      "default": "./build/esm/public/ontology-graph.js"
    },
    "./styles.css": "./build/esm/styles.css",
    "./*": {
      "import": {
        "types": "./build/types/public/*.d.ts",
        "default": "./build/esm/public/*.js"
      },
      "default": "./build/esm/public/*.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "check-spelling": "cspell --quiet .",
    "clean": "rm -rf lib dist types build tsconfig.tsbuildinfo",
    "codegen": "vite build --mode codegen",
    "dev": "vite",
    "fix-lint": "eslint . --fix && dprint fmt",
    "lint": "eslint . && dprint check",
    "preview": "vite preview",
    "test": "vitest run",
    "transpileEsm": "monorepo.tool.transpile -f esm -m normal -t node && node scripts/build-css.mjs",
    "transpileTypes": "monorepo.tool.transpile -f esm -m types -t node",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.10.0",
    "@blueprintjs/icons": "^6.7.0",
    "@dagrejs/dagre": "^1.1.1",
    "@osdk/generator-converters": "workspace:*",
    "@xyflow/react": "^12.4.3",
    "classnames": "2.3.2"
  },
  "peerDependencies": {
    "@osdk/api": "*",
    "@types/react": "^17 || ^18 || ^19",
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19"
  },
  "devDependencies": {
    "@osdk/api": "workspace:*",
    "@osdk/foundry.ontologies": "catalog:foundry-platform-typescript",
    "@osdk/monorepo.api-extractor": "workspace:~",
    "@osdk/monorepo.tsconfig": "workspace:~",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-router": "1.114.35",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^16.8.1",
    "normalize.css": "^8.0.1",
    "postcss": "^8.4",
    "postcss-modules": "^6.0.1",
    "prettier": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass-embedded": "^1.78.0",
    "typescript": "~5.5.4",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^7.0.0",
    "vite-plugin-sass-dts": "^1.3.35",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build/esm",
    "build/types",
    "CHANGELOG.md",
    "package.json",
    "templates",
    "*.d.ts"
  ],
  "module": "./build/esm/index.js",
  "type": "module"
}
