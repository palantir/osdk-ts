{
  "name": "@osdk/react-inspect",
  "version": "0.1.0",
  "description": "Point-and-click React component inspector (fiber traversal, highlight overlay, and optional OSDK ontology detection)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/palantir/osdk-ts.git"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./build/types/index.d.ts",
        "default": "./build/esm/index.js"
      },
      "default": "./build/esm/index.js"
    },
    "./fiber": {
      "import": {
        "types": "./build/types/public/fiber.d.ts",
        "default": "./build/esm/public/fiber.js"
      },
      "default": "./build/esm/public/fiber.js"
    },
    "./styles.css": "./build/esm/styles.css",
    "./*": {
      "import": {
        "types": "./build/types/public/*.d.ts",
        "default": "./build/esm/public/*.js"
      },
      "default": "./build/esm/public/*.js"
    }
  },
  "scripts": {
    "check-attw": "attw --profile esm-only --pack . --exclude-entrypoints ./styles.css",
    "check-spelling": "cspell --quiet .",
    "clean": "rm -rf lib dist types build tsconfig.tsbuildinfo",
    "fix-lint": "oxlint -c ../../oxlint.config.ts --fix . && oxfmt -c ../../oxfmt.config.ts .",
    "lint": "oxlint -c ../../oxlint.config.ts . && oxfmt -c ../../oxfmt.config.ts --check .",
    "test": "vitest run",
    "transpileEsm": "monorepo.tool.transpile -f esm -m normal -t node && node scripts/build-css.mjs",
    "transpileTypes": "monorepo.tool.transpile -f esm -m types -t node",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "peerDependencies": {
    "@types/react": "^17 || ^18 || ^19",
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19"
  },
  "devDependencies": {
    "@osdk/monorepo.api-extractor": "workspace:~",
    "@osdk/monorepo.tsconfig": "workspace:~",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@types/react-reconciler": "^0.28.0",
    "happy-dom": "^16.8.1",
    "postcss": "^8.4",
    "postcss-modules": "^6.0.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sass-embedded": "^1.89.2",
    "typescript": "~5.5.4",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build/esm",
    "build/types",
    "CHANGELOG.md",
    "package.json",
    "templates",
    "*.d.ts"
  ],
  "module": "./build/esm/index.js",
  "types": "./build/types/index.d.ts",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/styles.js"
  ],
  "type": "module"
}
