{
  "name": "@osdk/vite-plugin-superrepo",
  "version": "0.10.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/palantir/osdk-ts.git"
  },
  "exports": {
    ".": {
      "browser": "./build/browser/index.js",
      "import": {
        "types": "./build/types/index.d.ts",
        "default": "./build/esm/index.js"
      },
      "require": "./build/cjs/index.cjs",
      "default": "./build/browser/index.js"
    },
    "./discovery": {
      "browser": "./build/browser/public/discovery.js",
      "import": {
        "types": "./build/types/public/discovery.d.ts",
        "default": "./build/esm/public/discovery.js"
      },
      "require": "./build/cjs/public/discovery.cjs",
      "default": "./build/browser/public/discovery.js"
    },
    "./osdkClient": {
      "browser": "./build/browser/public/osdkClient.js",
      "import": {
        "types": "./build/types/public/osdkClient.d.ts",
        "default": "./build/esm/public/osdkClient.js"
      },
      "require": "./build/cjs/public/osdkClient.cjs",
      "default": "./build/browser/public/osdkClient.js"
    },
    "./smartClient": {
      "browser": "./build/browser/public/smartClient.js",
      "import": {
        "types": "./build/types/public/smartClient.d.ts",
        "default": "./build/esm/public/smartClient.js"
      },
      "require": "./build/cjs/public/smartClient.cjs",
      "default": "./build/browser/public/smartClient.js"
    },
    "./*": {
      "browser": "./build/browser/public/*.js",
      "import": {
        "types": "./build/types/public/*.d.ts",
        "default": "./build/esm/public/*.js"
      },
      "require": "./build/cjs/public/*.cjs",
      "default": "./build/browser/public/*.js"
    }
  },
  "scripts": {
    "check-attw": "attw --pack .",
    "check-spelling": "cspell --quiet .",
    "clean": "rm -rf lib dist types build tsconfig.tsbuildinfo",
    "fix-lint": "oxlint -c ./oxlint.config.ts --fix . && oxfmt -c ../../oxfmt.config.ts .",
    "lint": "oxlint -c ./oxlint.config.ts . && oxfmt -c ../../oxfmt.config.ts --check .",
    "test": "vitest run",
    "transpileBrowser": "monorepo.tool.transpile -f esm -m normal -t browser",
    "transpileCjs": "monorepo.tool.transpile -f cjs -m bundle -t node",
    "transpileEsm": "monorepo.tool.transpile -f esm -m normal -t node",
    "transpileTypes": "monorepo.tool.transpile -f esm -m types -t node",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "peerDependencies": {
    "@osdk/client": "*",
    "vite": "*"
  },
  "devDependencies": {
    "@osdk/monorepo.api-extractor": "workspace:~",
    "@osdk/monorepo.tsconfig": "workspace:~",
    "@types/node": "^20.19.13",
    "typescript": "~6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build/cjs",
    "build/esm",
    "build/browser",
    "build/types",
    "CHANGELOG.md",
    "package.json",
    "templates",
    "*.d.ts"
  ],
  "main": "./build/cjs/index.cjs",
  "module": "./build/esm/index.js",
  "types": "./build/cjs/index.d.cts",
  "type": "module"
}
