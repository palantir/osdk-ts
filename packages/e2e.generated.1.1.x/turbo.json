{
  "extends": ["//"],
  "tasks": {
    "typecheck": {
      "outputLogs": "new-only",
      "inputs": [
        "bin/**",
        "src/**",
        "src/**/*.{mts,cts,ts,tsx}",
        "tsconfig.json",
        "typecheck.sh",
        "tsconfig.cjs.json",
        "*.d.ts"
      ],
      "outputs": [
        // Includes `cts`: typecheck.sh renames the CJS `*.d.ts` to `*.d.cts`,
        // and those declarations must be cached/restored so check-attw (which
        // packs build/cjs) finds the CJS types when this task is a cache hit.
        "build/{esm,cjs,browser}/**/*.{ts,cts,cjs,ts.map,cts.map}"
      ],
      "dependsOn": [
        "@osdk/monorepo.tsconfig#typecheck",
        "^typecheck",
        "^transpile",
        // Own transpile too: transpile and typecheck both write build/cjs (and
        // typecheck.sh deletes existing *.ts/*.cts there first), so they must
        // not run concurrently or typecheck's *.d.cts can be clobbered.
        "transpile",
        "codegen"
      ]
    },

    "codegen": {
      "inputs": ["ontology.json"],
      "outputs": ["src/generatedNoCheck/**/*"],
      "dependsOn": ["@osdk/cli.cmd.typescript#transpileEsm"]
    },

    "transpile": {
      "outputLogs": "new-only",
      "dependsOn": [
        "@osdk/monorepo.tsconfig#typecheck",
        "^transpile",
        "transpileLegacy",
        "codegen"
      ],
      "inputs": [
        "bin/**",
        "src/**",
        "tsdown.config.ts",
        "tsconfig.json",
        "tsconfig.cjs.json",
        "transpile.sh"
      ],
      "outputs": ["dist/**", "lib/**", "build/**/*.{js,cjs,js.map,cjs.map}"]
    },

    "transpileLegacy": {
      "outputLogs": "new-only",
      "dependsOn": [
        "@osdk/monorepo.tsconfig#typecheck",
        "^typecheck",
        "^transpile",
        "codegen"
      ],
      "inputs": [
        "bin/**",
        "src/**",
        "templates/**",
        "tsdown.config.ts",
        "tsconfig.json",
        "tsconfig.cjs.json"
      ],
      "outputs": ["dist/**", "lib/**", "build/{esm,cjs,browser}/*"]
    }
  }
}
