import {
  Client,
  createClient,
  createPlatformClient,
  PlatformClient,
} from "@osdk/client";
import { FOUNDRY_URL{{#if osdkPackage}}, ONTOLOGY_RID{{/if}} } from "./osdkConst";
import { getValidAuthToken } from "./Auth";

{{#if osdkPackage}}
/**
 * Initialize the client to interact with the Ontology and Platform SDKs
 */
export const client: Client = createClient(
    FOUNDRY_URL, 
    ONTOLOGY_RID, 
    getValidAuthToken,
);
{{else}}
/**
 * Initialize the client to interact with the Platform SDK
 *
 * If you later add an Ontology SDK to your application, follow the steps in 
 * {{foundryUrl}}/docs/foundry/ontology-sdk/add-osdk-to-bootstrapped-repository/
 * to correctly set it up in this project.
 */
export const client: PlatformClient = createPlatformClient(FOUNDRY_URL, getValidAuthToken);
{{/if}}
