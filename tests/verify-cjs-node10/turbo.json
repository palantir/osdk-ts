{
  "extends": ["//"],
  "tasks": {
    "codegen": {
      "outputs": ["osdk/@test-app2/**/*"],
      "dependsOn": [
        "@osdk/tool.generate-with-mock-ontology#transpile",
        "@osdk/foundry-sdk-generator#transpile",
        "@osdk/shared.test#transpile",
        "^transpile"
      ]
    },
    "typecheck": {
      "outputs": ["./lib"]
    },
    "test": {
      "dependsOn": ["typecheck"],
      "inputs": ["./lib/**/*.js"]
    }
  }
}
