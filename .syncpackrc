{
  "$schema": "./node_modules/syncpack/schema.json",
  "sortFirst": [
    "name",
    "version",
    "private",
    "description",
    "license",
    "type",
    "main",
    "module",
    "types",
    "exports",
    "files",
    "scripts",
    "dependencies",
    "devDependencies",
    "peerDependencies",
    "peerDependenciesMeta"
  ],
  "versionGroups": [
    {
      "label": "Use workspace:~ for local @osdk/monorepo.* packages",
      "dependencies": [
        "@osdk/monorepo.*"
      ],
      "dependencyTypes": [
        "dev",
        "prod"
      ],
      "pinVersion": "workspace:~"
    },
    {
      "label": "Use workspace protocol for all other local packages",
      "dependencies": [
        "$LOCAL"
      ],
      "dependencyTypes": [
        "dev",
        "prod"
      ],
      "pinVersion": "workspace:~"
    }
  ]
}
