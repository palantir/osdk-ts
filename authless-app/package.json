{
  "name": "authless-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "format": "prettier --write src/",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint --report-unused-disable-directives --max-warnings 0 --fix",
    "test": "vitest run",
    "check": "eslint . --report-unused-disable-directives --max-warnings 0 && tsc --noEmit && vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@rc-public-message-board-app/sdk": "latest",
    "@osdk/client": "^2.8.0",
    "@osdk/foundry": "latest",
    "@osdk/oauth": "^1.1.0",
    "@blueprintjs/core": "^6.10.0",
    "@blueprintjs/icons": "^6.7.0",
    "normalize.css": "^8.0.1",
    "react": "^18",
    "react-dom": "^18",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.0.0",
    "prettier": "^3.0.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.35.0",
    "@osdk/create-app.react.beta.common": "workspace:~",
    "@types/eslint-plugin-jsx-a11y": "^6.10.0",
    "@types/node": "^24.12.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "typescript": "~5.5.4",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}